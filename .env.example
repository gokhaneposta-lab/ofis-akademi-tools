# Resend (e-posta gönderimi + Audience kişi listesi) — https://resend.com
# Abone formu: hoş geldin maili gönderir ve kişiyi Resend → Audience → Contacts listesine ekler.
RESEND_API_KEY=re_xxxxxxxxxxxx

# Opsiyonel: Gönderen adresi (yoksa onboarding@resend.dev kullanılır)
# RESEND_FROM=Ofis Akademi <info@siteniz.com>

# Canlı site (ofisakademi.com): e-postadaki linkler bu adrese gider — production'da mutlaka ayarlayın
# NEXT_PUBLIC_SITE_URL=https://ofisakademi.com
