# Resend (e-posta gönderimi + Audience kişi listesi) — https://resend.com
# Abone formu: hoş geldin maili gönderir ve kişiyi Resend → Kitle → İletişim listesine ekler.
# Önemli: Kişi eklemek için API anahtarı "Full access" (Tam erişim) olmalı.
# Yalnızca "Sending access" (Gönderim) seçilirse mail gider ama Contacts API 403 verir.
RESEND_API_KEY=re_xxxxxxxxxxxx

# Opsiyonel: Gönderen adresi (yoksa onboarding@resend.dev kullanılır)
# RESEND_FROM=Ofis Akademi <info@siteniz.com>

# Canlı site (kanonik adres) — production'da mutlaka ayarlayın.
# Şu an kanonik: www'lu adres. ofisakademi.com → www.ofisakademi.com'a 308 ile yönleniyor.
# NEXT_PUBLIC_SITE_URL=https://www.ofisakademi.com

# Gizli bütçe paneli (/butce) — sadece sunucu tarafı; repoya koymayın.
# BUTCE_USERS=gokhan:Sifre1,ayse:Sifre2,mehmet:Sifre3,fatma:Sifre4
# BUTCE_SESSION_TOKEN=rastgele-uzun-dize-openssl-rand-hex-32
# Vercel'de MIZAN/prim verisi için Blob Store (Dashboard → Storage → Blob):
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
